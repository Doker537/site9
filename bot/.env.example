# Comma-separated list of allowed frontend origins (no trailing slash)
# Example: https://yoursite.com,https://www.yoursite.com
ALLOWED_ORIGINS=https://yoursite.com

# VK API Access Token (Group or User token)
VK_TOKEN=your_vk_token_here

# ID of the VK chat or user to send messages to
# For users: user_id (e.g. 123456)
# For group chats: 2000000000 + chat_id
VK_PEER_ID=your_target_id_here

# Telegram Bot Token (from @BotFather)
TG_TOKEN=your_telegram_bot_token_here

# Telegram Chat ID (your personal ID or group ID)
TG_CHAT_ID=your_telegram_chat_id_here
